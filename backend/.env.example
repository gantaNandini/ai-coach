# ============================================================
# AI Coach Platform — Environment Variables
# ============================================================
# Copy to .env and fill in real values.
# NEVER commit .env (only .env.example) to version control.
# ALL values here are placeholders only.
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_NAME=AI Coach
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=false
API_V1_PREFIX=/api/v1
FRONTEND_URL=http://localhost:5173
APP_BASE_URL=http://localhost:5173

# ── Security — REQUIRED, no defaults ─────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_32_CHARS_MINIMUM_NO_DEFAULT
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Database — REQUIRED, no default ──────────────────────────
# Use app_role (non-owner) so RLS policies are enforced:
#   CREATE ROLE app_role WITH LOGIN PASSWORD '...';
#   GRANT SELECT,INSERT,UPDATE,DELETE ON ALL TABLES IN SCHEMA public TO app_role;
DATABASE_URL=postgresql+asyncpg://app_role:CHANGE_ME@localhost:5432/aicoach
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30

# ── Redis — REQUIRED for background jobs ─────────────────────
REDIS_URL=redis://localhost:6379/0

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=["https://your-domain.com"]

# ── LLM Provider ─────────────────────────────────────────────
LLM_PROVIDER=ollama
# ollama settings (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:latest
OLLAMA_TIMEOUT=120
OLLAMA_MAX_TOKENS=2048
OLLAMA_TEMPERATURE=0.7
# Claude settings (used when LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=CHANGE_ME_IF_USING_CLAUDE
CLAUDE_MODEL=claude-haiku-4-5

# ── Embeddings ───────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-base
EMBEDDING_DIMENSION=384
EMBEDDING_BATCH_SIZE=32

# ── RAG ──────────────────────────────────────────────────────
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_TOP_K=6
RAG_SCORE_THRESHOLD=0.35
RAG_TOKEN_BUDGET=2048

# ── Object Storage ────────────────────────────────────────────
STORAGE_BACKEND=local
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
ALLOWED_UPLOAD_EXTENSIONS=[".pdf",".docx",".pptx",".txt",".md"]
# S3/MinIO (set STORAGE_BACKEND=s3 and fill these)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=CHANGE_ME
S3_SECRET_ACCESS_KEY=CHANGE_ME
S3_BUCKET=aicoach-uploads
S3_REGION=us-east-1

# ── Email ─────────────────────────────────────────────────────
EMAIL_PROVIDER=none
RESEND_API_KEY=CHANGE_ME
POSTMARK_SERVER_TOKEN=CHANGE_ME
EMAIL_FROM=noreply@yourdomain.com

# ── Billing (Stripe) ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_PRICE_ID_STARTER=price_CHANGE_ME
STRIPE_PRICE_ID_PRO=price_CHANGE_ME

# ── Observability ────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=INFO
LOG_FORMAT=json
