# ============================================================
# AI Coach Platform — Production Environment Template
# ============================================================
# Copy this file to .env (or inject via your secrets manager).
# NEVER commit real secrets to version control.
#
# Required vars are marked [REQUIRED].
# Optional vars with safe defaults are marked [OPTIONAL].
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_NAME=AI Coach
APP_VERSION=1.0.0

# Set to "production" — disables debug mode & enables HSTS header
ENVIRONMENT=production     # [REQUIRED]

# Must be false in production
DEBUG=false                # [REQUIRED]

API_V1_PREFIX=/api/v1      # [OPTIONAL]

# Public-facing base URL used for Stripe redirect URLs
APP_BASE_URL=https://your-domain.com   # [REQUIRED for billing]

# ── Security ─────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_HEX   # [REQUIRED]
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ─────────────────────────────────────────────────
# Use a dedicated production user with least-privilege permissions.
# Enable SSL: ?ssl=require (recommended for cloud DBs)
DATABASE_URL=postgresql+asyncpg://aicoach_prod:REPLACE_PASSWORD@db.your-domain.com:5432/aicoach?ssl=require   # [REQUIRED]
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_POOL_TIMEOUT=30

# ── Ollama / LLM ─────────────────────────────────────────────
# Point to your production Ollama instance (or swap for OpenAI-compatible API)
OLLAMA_BASE_URL=http://ollama:11434    # [REQUIRED]
OLLAMA_MODEL=qwen3:4b                  # [REQUIRED — pull this model first]
OLLAMA_TIMEOUT=120
OLLAMA_MAX_TOKENS=2048
OLLAMA_TEMPERATURE=0.7

# ── Embeddings ───────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384
EMBEDDING_BATCH_SIZE=32

# ── RAG ──────────────────────────────────────────────────────
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_TOP_K=6
RAG_SCORE_THRESHOLD=0.35
RAG_TOKEN_BUDGET=2048

# ── File uploads ─────────────────────────────────────────────
# In production, use an S3-compatible store and set UPLOAD_DIR to a mounted volume.
UPLOAD_DIR=/app/uploads   # [OPTIONAL — ensure this directory is writable]
MAX_UPLOAD_SIZE_MB=50
ALLOWED_UPLOAD_EXTENSIONS=[".pdf",".docx",".pptx",".txt",".md"]

# ── CORS ─────────────────────────────────────────────────────
# Restrict to your real frontend origin(s) in production.
ALLOWED_ORIGINS=["https://your-domain.com","https://app.your-domain.com"]   # [REQUIRED]

# ── Billing (Stripe) ─────────────────────────────────────────
# Leave empty to disable billing UI; set to enable checkout + webhooks.
STRIPE_SECRET_KEY=sk_live_REPLACE_WITH_REAL_KEY         # [OPTIONAL]
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_REAL_SECRET    # [OPTIONAL]

# ── Monitoring / observability ───────────────────────────────
# Sentry DSN — optional but highly recommended for production error tracking
SENTRY_DSN=                # [OPTIONAL]

# Log level for production (use WARNING or ERROR to reduce noise)
LOG_LEVEL=INFO             # [OPTIONAL]
